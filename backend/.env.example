# Copie este archivo a .env y rellene con sus credenciales reales.
# No suba .env al repositorio.

# ─── Base de datos ────────────────────────────────────────────────────────────
# Pooler sesión/directo (puerto 5432) — usado por Prisma en este backend.
# Ejemplo Supabase: postgresql://postgres.xxx:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Pooler transaccional (puerto 6543) — alternativa para entornos serverless.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres"

# Direct connection — solo si DIRECT_URL sigue dando timeout.
# Déjelo vacío si no lo necesita. NO use "postgresql://ruta".
DATABASE_APP_URL=""

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="cambie-esta-clave-por-una-segura"
JWT_EXPIRES_IN="1d"

# ─── Seed (admin inicial) ─────────────────────────────────────────────────────
ADMIN_EMAIL="admin@institucion.edu.ec"
ADMIN_PASSWORD="Admin123456"

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL="http://localhost:5173"

# ─── Chatbot (OpenAI compatible) ──────────────────────────────────────────────
CHATBOT_API_KEY=""
